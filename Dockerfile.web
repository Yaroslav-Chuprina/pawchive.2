FROM node:24-slim AS builder
RUN corepack enable && corepack prepare pnpm@latest --activate
WORKDIR /app

COPY pnpm-workspace.yaml pnpm-lock.yaml package.json tsconfig.json tsconfig.base.json ./
COPY lib/ lib/
COPY artifacts/pawchive/ artifacts/pawchive/
COPY scripts/ scripts/

RUN pnpm install --frozen-lockfile --ignore-scripts
RUN BASE_PATH=/ pnpm --filter @workspace/pawchive run build

FROM nginx:alpine
COPY --from=builder /app/artifacts/pawchive/dist /usr/share/nginx/html
COPY nginx.conf /etc/nginx/conf.d/default.conf
EXPOSE 80
