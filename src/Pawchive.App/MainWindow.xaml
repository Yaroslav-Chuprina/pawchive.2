<Window x:Class="Pawchive.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="{Binding WindowTitle}"
        Height="720"
        Width="1180"
        MinHeight="620"
        MinWidth="960"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource AppBackgroundBrush}">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="232" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Background="{StaticResource PanelBrush}">
            <Grid Margin="22">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="32" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <StackPanel>
                    <TextBlock Text="Pawchive" FontSize="26" FontWeight="SemiBold" />
                    <TextBlock Text="Local content library" Foreground="{StaticResource MutedTextBrush}" Margin="0,4,0,0" />
                </StackPanel>

                <StackPanel Grid.Row="2">
                    <TextBlock Text="Dashboard" FontSize="15" FontWeight="SemiBold" Margin="0,0,0,18" />
                    <TextBlock Text="Authors" Foreground="{StaticResource MutedTextBrush}" Margin="0,0,0,14" />
                    <TextBlock Text="Posts" Foreground="{StaticResource MutedTextBrush}" Margin="0,0,0,14" />
                    <TextBlock Text="Downloads" Foreground="{StaticResource MutedTextBrush}" Margin="0,0,0,14" />
                    <TextBlock Text="Settings" Foreground="{StaticResource MutedTextBrush}" />
                </StackPanel>

                <TextBlock Grid.Row="3"
                           Text="{Binding StatusMessage}"
                           Foreground="{StaticResource MutedTextBrush}"
                           TextWrapping="Wrap" />
            </Grid>
        </Border>

        <Grid Grid.Column="1" Margin="30">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="24" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="32" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <StackPanel>
                <TextBlock Text="{Binding WindowTitle}" FontSize="30" FontWeight="SemiBold" />
                <TextBlock Text="Application shell, storage, database and plugins are ready."
                           Foreground="{StaticResource MutedTextBrush}"
                           Margin="0,8,0,0" />
            </StackPanel>

            <ItemsControl Grid.Row="2" ItemsSource="{Binding Metrics}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <UniformGrid Columns="4" />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Style="{StaticResource MetricCardStyle}">
                            <StackPanel>
                                <TextBlock Text="{Binding Label}" Foreground="{StaticResource MutedTextBrush}" />
                                <TextBlock Text="{Binding Value}" FontSize="30" FontWeight="SemiBold" Margin="0,8,0,4" />
                                <TextBlock Text="{Binding Detail}"
                                           Foreground="{StaticResource MutedTextBrush}"
                                           TextTrimming="CharacterEllipsis" />
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <Border Grid.Row="4"
                    Background="{StaticResource CardBrush}"
                    CornerRadius="8"
                    Padding="24">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="16" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <TextBlock Text="Next implementation area" FontSize="20" FontWeight="SemiBold" />
                    <TextBlock Grid.Row="2"
                               Text="Queue manager, author catalog and library browser can now be added on top of this foundation."
                               Foreground="{StaticResource MutedTextBrush}"
                               TextWrapping="Wrap" />
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>
