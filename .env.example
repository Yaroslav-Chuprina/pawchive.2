# Copy this file to .env and fill in your values.
# Docker Compose automatically reads .env from the project root.

# Postgres password (default: pawchive — change for production)
DB_PASSWORD=pawchive

# Session secret — generate with: openssl rand -hex 32
SESSION_SECRET=replace-with-a-random-secret

# Port that Pawchive will be accessible on your PC
# Using 7890 — change this if it happens to be taken
PORT=7890
